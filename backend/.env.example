# AI provider: gemini or openai. If omitted, Gemini is used when GEMINI_API_KEY exists.
AI_PROVIDER=gemini

# PostgreSQL
DATABASE_URL=postgresql://ggads:ggads_local_password@localhost:5432/ggads
DATABASE_SSL=false
DATABASE_POOL_SIZE=10
DATABASE_LOGGING=false
DATABASE_SYNCHRONIZE=true
DATABASE_SEED_ENABLED=true
DEFAULT_GOOGLE_ADS_CUSTOMER_ID=9920642691

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI fallback, optional
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
